{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Quota Beacon",
  "version": "1.5.3",
  "identifier": "app.quotabeacon.desktop",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "widget",
        "title": "Quota Beacon",
        "width": 100,
        "height": 100,
        "minWidth": 80,
        "minHeight": 80,
        "maxWidth": 360,
        "maxHeight": 360,
        "resizable": true,
        "decorations": false,
        "transparent": true,
        "alwaysOnTop": true,
        "skipTaskbar": true,
        "shadow": false,
        "visible": true
      },
      {
        "label": "palette",
        "title": "Quota Beacon Palette Preview",
        "url": "index.html?palette",
        "width": 320,
        "height": 104,
        "resizable": false,
        "decorations": false,
        "transparent": true,
        "alwaysOnTop": true,
        "skipTaskbar": true,
        "shadow": false,
        "visible": false
      },
      {
        "label": "palette-editor",
        "title": "Quota Beacon Palette Editor",
        "url": "index.html?palette-editor",
        "width": 320,
        "height": 104,
        "resizable": false,
        "decorations": false,
        "transparent": true,
        "alwaysOnTop": true,
        "skipTaskbar": true,
        "shadow": false,
        "visible": false
      }
    ],
    "security": { "csp": "default-src 'self'; style-src 'self' 'unsafe-inline'; connect-src 'self'; img-src 'self' data:" }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "macOS": {
      "signingIdentity": "-"
    },
    "category": "Utility",
    "shortDescription": "Codex usage limits at a glance",
    "longDescription": "A local-first floating desktop card for monitoring Codex usage limits.",
    "copyright": "Copyright 2026 Quota Beacon contributors",
    "icon": ["icons/32x32.png", "icons/128x128.png", "icons/128x128@2x.png", "icons/icon.icns", "icons/icon.ico"]
  }
}
